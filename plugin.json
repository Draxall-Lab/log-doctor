{
  "name": "log-doctor",
  "display_name": "Log Doctor",
  "short_name": "Log Doctor",
  "version": "0.4.1",
  "description": "Diagnoses Sapphire issues using logs and a structured diagnostics panel.",
  "author": "Draxall",
  "icon": "🩺",
  "default_enabled": true,
  "capabilities": {
    "hooks": {
      "pre_chat": "hooks/context.py",
      "prompt_inject": "hooks/context.py"
    },
    "routes": [
      {
        "method": "POST",
        "path": "report",
        "handler": "routes/report.py:handle_report"
      },
      {
        "method": "POST",
        "path": "analyse",
        "handler": "routes/analyse.py:handle"
      },
      {
        "method": "GET",
        "path": "meta",
        "handler": "routes/meta.py:handle"
}
    ],
    "app": {
      "label": "Log Doctor",
      "icon": "🩺",
      "description": "Structured log diagnostics console",
      "nav": true
    },
    "settings": [
      {
        "key": "sapphire_root",
        "type": "string",
        "label": "Sapphire Root",
        "default": "",
        "help": "Optional override path to Sapphire root folder."
      }
    ]
  }
}